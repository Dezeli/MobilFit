{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"]},"docs":[{"location":"","title":"\ud83d\udec2 Mobilfit API \ubb38\uc11c","text":"<p>\ubaa8\ub4e0 API\ub294 <code>https://mobilfit.kr/api/v1/</code> \ud558\uc704\uc5d0\uc11c \ub3d9\uc791\ud569\ub2c8\ub2e4. \uc751\ub2f5\uc740 \uc544\ub798\uc758 \uacf5\ud1b5 \ud3ec\ub9f7\uc744 \ub530\ub985\ub2c8\ub2e4.</p> <pre><code>// \uc131\uacf5 \uc2dc\n{\n  \"success\": true,\n  \"data\": {\n    \"\ud544\ub4dc\uba85\": \"\uc124\uba85\"\n  }\n}\n\n// \uc2e4\ud328 \uc2dc\n{\n  \"success\": false,\n  \"data\": {\n    \"\ud544\ub4dc\uba85\": \"\uc124\uba85\"\n  }\n}\n</code></pre>"},{"location":"#_1","title":"\ud83d\udcda \ubaa9\ucc28","text":"<ul> <li>Auth API</li> </ul>"},{"location":"auth/","title":"\ud83d\udd10 Auth API","text":"<p><code>/auth/</code> \ud558\uc704\uc5d0\uc11c \ub3d9\uc791\ud558\ub294 \uc778\uc99d \uad00\ub828 API \ubaa9\ub85d\uc785\ub2c8\ub2e4.</p> \uae30\ub2a5 \uba54\uc11c\ub4dc \uc5d4\ub4dc\ud3ec\uc778\ud2b8 \ud68c\uc6d0\uac00\uc785 POST <code>/auth/signup/</code> \ub85c\uadf8\uc778 POST <code>/auth/login/</code> \ub85c\uadf8\uc544\uc6c3 POST <code>/auth/logout/</code> \ud1a0\ud070 \uac31\uc2e0 POST <code>/auth/token/refresh/</code> \uc774\uba54\uc77c \uc778\uc99d \ucf54\ub4dc \uc804\uc1a1 POST <code>/auth/email-verify/send/</code> \uc774\uba54\uc77c \uc778\uc99d \ud655\uc778 POST <code>/auth/email-verify/confirm/</code> \uc544\uc774\ub514 \ucc3e\uae30 POST <code>/auth/find-id/</code> \uc784\uc2dc \ube44\ubc00\ubc88\ud638 \uc804\uc1a1 POST <code>/auth/reset-password/</code> \ube44\ubc00\ubc88\ud638 \ubcc0\uacbd POST <code>/auth/change-password/</code> \ud1a0\ud070 \uac80\uc99d GET <code>/auth/me/</code> \ub9c8\uc774\ud398\uc774\uc9c0 \uc815\ubcf4 GET <code>/auth/user/mypage/</code>"},{"location":"auth/change_password/","title":"\u2705 \ube44\ubc00\ubc88\ud638 \ubcc0\uacbd API","text":""},{"location":"auth/change_password/#post-authchange-password","title":"\ud83d\udd3d POST <code>/auth/change-password/</code>","text":"<p>\ub85c\uadf8\uc778\ub41c \uc0ac\uc6a9\uc790\uac00 \ud604\uc7ac \ube44\ubc00\ubc88\ud638\ub97c \ud655\uc778\ud55c \ud6c4 \uc0c8 \ube44\ubc00\ubc88\ud638\ub85c \ubcc0\uacbd\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/change_password/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"current_password\": \"oldpassword123\",\n  \"new_password\": \"newsecurepassword456\"\n}\n</code></pre>"},{"location":"auth/change_password/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": null\n}\n</code></pre>"},{"location":"auth/change_password/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"current_password\": \"\ud604\uc7ac \ube44\ubc00\ubc88\ud638\uac00 \uc62c\ubc14\ub974\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/change_password/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\uc0ac\uc6a9\uc790\ub294 \ubc18\ub4dc\uc2dc \ub85c\uadf8\uc778 \uc0c1\ud0dc\uc5ec\uc57c \ud569\ub2c8\ub2e4 (JWT access token \ud544\uc694).</li> <li><code>current_password</code>\uac00 \uc815\ud655\ud788 \uc77c\uce58\ud574\uc57c \ube44\ubc00\ubc88\ud638 \ubcc0\uacbd\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</li> <li><code>new_password</code>\ub294 \ucd5c\uc18c 8\uc790 \uc774\uc0c1\uc774\uc5b4\uc57c \ud558\uba70, \ubcc0\uacbd \uc2dc \uc989\uc2dc \ubc18\uc601\ub429\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/email_confirm/","title":"\u2705 \uc774\uba54\uc77c \uc778\uc99d \ud655\uc778 API","text":""},{"location":"auth/email_confirm/#post-authemail-verifyconfirm","title":"\ud83d\udd3d POST <code>/auth/email-verify/confirm/</code>","text":"<p>\uc0ac\uc6a9\uc790\uac00 \ubc1b\uc740 \uc778\uc99d \ucf54\ub4dc\ub97c \uc785\ub825\ud558\uc5ec \uc774\uba54\uc77c \uc778\uc99d\uc744 \uc644\ub8cc\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/email_confirm/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"email\": \"user@example.com\",\n  \"code\": \"123456\"\n}\n</code></pre>"},{"location":"auth/email_confirm/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": null\n}\n</code></pre>"},{"location":"auth/email_confirm/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"code\": \"\uc778\uc99d \ucf54\ub4dc\uac00 \uc77c\uce58\ud558\uc9c0 \uc54a\uac70\ub098 \ub9cc\ub8cc\ub418\uc5c8\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/email_confirm/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\uc778\uc99d \ucf54\ub4dc\ub294 5\ubd84\uc774 \uc9c0\ub098\uba74 \ub9cc\ub8cc\ub429\ub2c8\ub2e4.</li> <li>\uc778\uc99d\uc774 \uc644\ub8cc\ub41c \uc774\uba54\uc77c\uc740 \uc7ac\uc778\uc99d\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4.</li> <li>\uc774\uba54\uc77c \uc778\uc99d\uc774 \uc644\ub8cc\ub418\uc5b4\uc57c\ub9cc \ud68c\uc6d0\uac00\uc785\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/email_send/","title":"\u2705 \uc774\uba54\uc77c \uc778\uc99d \ucf54\ub4dc \uc804\uc1a1 API","text":""},{"location":"auth/email_send/#post-authemail-verifysend","title":"\ud83d\udd3d POST <code>/auth/email-verify/send/</code>","text":"<p>\ud68c\uc6d0\uac00\uc785 \uc2dc \uc0ac\uc6a9\uc790\uc758 \uc774\uba54\uc77c\ub85c \uc778\uc99d \ucf54\ub4dc\ub97c \uc804\uc1a1\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/email_send/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"email\": \"user@example.com\"\n}\n</code></pre>"},{"location":"auth/email_send/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": null\n}\n</code></pre>"},{"location":"auth/email_send/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"email\": \"\uc774\ubbf8 \uac00\uc785\ub41c \uc774\uba54\uc77c\uc785\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/email_send/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\uc785\ub825\ub41c \uc774\uba54\uc77c \uc8fc\uc18c\ub85c 6\uc790\ub9ac \uc22b\uc790 \uc778\uc99d \ucf54\ub4dc\uac00 \uc804\uc1a1\ub429\ub2c8\ub2e4.</li> <li>\uc774\ubbf8 \uac00\uc785\ub41c \uc774\uba54\uc77c\uc77c \uacbd\uc6b0 \uc694\uccad\uc774 \uac70\uc808\ub429\ub2c8\ub2e4.</li> <li>\uc778\uc99d \ucf54\ub4dc\ub294 \uc77c\uc815 \uc2dc\uac04(\uc608: 5\ubd84) \ub3d9\uc548\ub9cc \uc720\ud6a8\ud558\uba70, \uc774\ud6c4 \ub9cc\ub8cc\ub429\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/find_id/","title":"\u2705 \uc544\uc774\ub514 \ucc3e\uae30 API","text":""},{"location":"auth/find_id/#post-authfind-id","title":"\ud83d\udd3d POST <code>/auth/find-id/</code>","text":"<p>\uac00\uc785\ub41c \uc774\uba54\uc77c\uc744 \uae30\ubc18\uc73c\ub85c \uc0ac\uc6a9\uc790\uc758 \uc544\uc774\ub514 \uc77c\ubd80\ub97c \ub9c8\uc2a4\ud0b9\ud558\uc5ec \ubc18\ud658\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/find_id/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"email\": \"user@example.com\"\n}\n</code></pre>"},{"location":"auth/find_id/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"masked_username\": \"use****123\"\n  }\n}\n</code></pre>"},{"location":"auth/find_id/#response-404","title":"\ud83d\udd39 Response 404","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"email\": \"\ud574\ub2f9 \uc774\uba54\uc77c\ub85c \uac00\uc785\ub41c \uc0ac\uc6a9\uc790\uac00 \uc5c6\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/find_id/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\ub9c8\uc2a4\ud0b9\ub41c \uc544\uc774\ub514\ub97c \ubc18\ud658\ud558\uc5ec \uac1c\uc778\uc815\ubcf4 \ub178\ucd9c\uc744 \ubc29\uc9c0\ud569\ub2c8\ub2e4.</li> <li>\ud574\ub2f9 \uc774\uba54\uc77c\ub85c \uac00\uc785\ub41c \uc0ac\uc6a9\uc790\uac00 \uc5c6\uc73c\uba74 404 \uc5d0\ub7ec\ub97c \ubc18\ud658\ud569\ub2c8\ub2e4.</li> <li>\ud68c\uc6d0\uac00\uc785 \uc2dc \ub4f1\ub85d\ud55c \uc774\uba54\uc77c \uc815\ubcf4\uc640 \uc815\ud655\ud788 \uc77c\uce58\ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/login/","title":"\u2705 \ub85c\uadf8\uc778 API","text":""},{"location":"auth/login/#post-authlogin","title":"\ud83d\udd3d POST <code>/auth/login/</code>","text":"<p>\uc0ac\uc6a9\uc790\uac00 \uc544\uc774\ub514\uc640 \ube44\ubc00\ubc88\ud638\ub85c \ub85c\uadf8\uc778\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/login/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"username\": \"new_user123\",\n  \"password\": \"securepassword\"\n}\n</code></pre>"},{"location":"auth/login/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"access\": \"eyJ0eXAiOiJKV1QiLCJhbGci...\",\n    \"refresh\": \"eyJ0eXAiOiJKV1QiLCJhbGci...\"\n  }\n}\n</code></pre>"},{"location":"auth/login/#response-401","title":"\ud83d\udd39 Response 401","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"non_field_errors\": \"\uc544\uc774\ub514 \ub610\ub294 \ube44\ubc00\ubc88\ud638\uac00 \uc62c\ubc14\ub974\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/login/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\ub85c\uadf8\uc778\uc5d0 \uc131\uacf5\ud558\uba74 <code>access</code>\uc640 <code>refresh</code> \ud1a0\ud070\uc774 \ubc1c\uae09\ub429\ub2c8\ub2e4.</li> <li>\ubc1c\uae09\ub41c \ud1a0\ud070\uc740 \uc774\ud6c4 \uc778\uc99d\uc774 \ud544\uc694\ud55c \uc694\uccad\uc5d0 \uc0ac\uc6a9\ub429\ub2c8\ub2e4.</li> <li>\uc785\ub825\uac12\uc774 \uc62c\ubc14\ub974\uc9c0 \uc54a\uac70\ub098 \uc0ac\uc6a9\uc790 \uc815\ubcf4\uac00 \uc77c\uce58\ud558\uc9c0 \uc54a\uc73c\uba74 \ub85c\uadf8\uc778\uc5d0 \uc2e4\ud328\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/logout/","title":"\u2705 \ub85c\uadf8\uc544\uc6c3 API","text":""},{"location":"auth/logout/#post-authlogout","title":"\ud83d\udd3d POST <code>/auth/logout/</code>","text":"<p>\uc0ac\uc6a9\uc790\uc758 refresh \ud1a0\ud070\uc744 \uc0ad\uc81c\ud558\uc5ec \ub85c\uadf8\uc544\uc6c3 \ucc98\ub9ac\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/logout/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"refresh\": \"eyJ0eXAiOiJKV1QiLCJhbGci...\"\n}\n</code></pre>"},{"location":"auth/logout/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": null\n}\n</code></pre>"},{"location":"auth/logout/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"refresh\": \"\uc720\ud6a8\ud558\uc9c0 \uc54a\uc740 \ud1a0\ud070\uc785\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/logout/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\uc11c\ubc84\uc5d0 \uc800\uc7a5\ub41c \uc0ac\uc6a9\uc790\uc758 refresh \ud1a0\ud070\uc744 \uc0ad\uc81c\ud569\ub2c8\ub2e4.</li> <li>\ud1a0\ud070\uc774 \uc5c6\uac70\ub098 \uc798\ubabb\ub41c \uacbd\uc6b0 \ub85c\uadf8\uc544\uc6c3\uc774 \uc2e4\ud328\ud569\ub2c8\ub2e4.</li> <li>\ub85c\uadf8\uc544\uc6c3 \ud6c4 \uc7ac\ub85c\uadf8\uc778\uc744 \uc704\ud574\uc11c\ub294 \ub2e4\uc2dc \ub85c\uadf8\uc778 \uc694\uccad\uc744 \ud574\uc57c \ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/me/","title":"\u2705 \ud1a0\ud070 \uac80\uc99d API","text":""},{"location":"auth/me/#get-authme","title":"\ud83d\udd3d GET <code>/auth/me/</code>","text":"<p>\ub85c\uadf8\uc778\ub41c \uc0ac\uc6a9\uc790\uc758 \uae30\ubcf8 \uc815\ubcf4\ub97c \ubc18\ud658\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/me/#request","title":"\ud83d\udd38 Request","text":"<p>\ud5e4\ub354\uc5d0 JWT access token\uc744 \ud3ec\ud568\ud574\uc57c \ud569\ub2c8\ub2e4.</p> <pre><code>Authorization: Bearer &lt;access_token&gt;\n</code></pre>"},{"location":"auth/me/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"username\": \"user123\",\n    \"email\": \"user@example.com\",\n    \"nickname\": \"\ubaa8\ube4c\ub7ec\"\n  }\n}\n</code></pre>"},{"location":"auth/me/#response-401","title":"\ud83d\udd39 Response 401","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"detail\": \"\uc720\ud6a8\ud558\uc9c0 \uc54a\uc740 \ud1a0\ud070\uc785\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/me/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\ud074\ub77c\uc774\uc5b8\ud2b8\uac00 \ubcf4\uc720\ud55c access token\uc758 \uc720\ud6a8\uc131\uc744 \uac80\uc99d\ud558\uace0 \uc0ac\uc6a9\uc790 \uc815\ubcf4\ub97c \ubc18\ud658\ud569\ub2c8\ub2e4.</li> <li>\uc774 API\ub294 \uc790\ub3d9 \ub85c\uadf8\uc778 \ub610\ub294 \uc138\uc158 \uc720\uc9c0\uc5d0 \uc0ac\uc6a9\ub429\ub2c8\ub2e4.</li> <li>\uc751\ub2f5 \ub370\uc774\ud130\ub294 \uc0ac\uc6a9\uc790 \uc2dd\ubcc4 \ubc0f \ud45c\uc2dc\uc6a9 \uc815\ubcf4\ub97c \ud3ec\ud568\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/reset_password/","title":"\u2705 \uc784\uc2dc \ube44\ubc00\ubc88\ud638 \uc804\uc1a1 API","text":""},{"location":"auth/reset_password/#post-authreset-password","title":"\ud83d\udd3d POST <code>/auth/reset-password/</code>","text":"<p>\uc785\ub825\ud55c \uc0ac\uc6a9\uc790 \uc815\ubcf4\ub97c \uae30\ubc18\uc73c\ub85c \uc784\uc2dc \ube44\ubc00\ubc88\ud638\ub97c \uc774\uba54\uc77c\ub85c \uc804\uc1a1\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/reset_password/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"username\": \"user123\",\n  \"email\": \"user@example.com\",\n  \"name\": \"\ud64d\uae38\ub3d9\"\n}\n</code></pre>"},{"location":"auth/reset_password/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": null\n}\n</code></pre>"},{"location":"auth/reset_password/#response-404","title":"\ud83d\udd39 Response 404","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"user\": \"\uc785\ub825\ud558\uc2e0 \uc815\ubcf4\uc640 \uc77c\uce58\ud558\ub294 \uc0ac\uc6a9\uc790\uac00 \uc5c6\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/reset_password/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"username\": \"\uc785\ub825\uac12\uc774 \uc720\ud6a8\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/reset_password/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\uc785\ub825\ud55c \uc0ac\uc6a9\uc790 \uc815\ubcf4\uac00 \uc815\ud655\ud788 \uc77c\uce58\ud574\uc57c \uc784\uc2dc \ube44\ubc00\ubc88\ud638\uac00 \ubc1c\uae09\ub429\ub2c8\ub2e4.</li> <li>\uc784\uc2dc \ube44\ubc00\ubc88\ud638\ub294 \uc774\uba54\uc77c\ub85c \uc804\uc1a1\ub418\uba70, \ub85c\uadf8\uc778 \ud6c4 \ubc18\ub4dc\uc2dc \ubcc0\uacbd\ud574\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uc774\ub984\uc740 \ub2c9\ub124\uc784\uacfc \ub3d9\uc77c\ud55c \ud544\ub4dc\ub85c \ucc98\ub9ac\ub429\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/signup/","title":"\u2705 \ud68c\uc6d0\uac00\uc785 API","text":""},{"location":"auth/signup/#post-authsignup","title":"\ud83d\udd3d POST <code>/auth/signup/</code>","text":"<p>\uc0c8\ub85c\uc6b4 \uc0ac\uc6a9\uc790\ub97c \ud68c\uc6d0\uac00\uc785 \uc2dc\ud0b5\ub2c8\ub2e4.</p>"},{"location":"auth/signup/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"username\": \"new_user123\",\n  \"password\": \"securepassword\",\n  \"nickname\": \"\ubaa8\ube4c\ub7ec\",\n  \"email\": \"user@example.com\"\n}\n</code></pre>"},{"location":"auth/signup/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"username\": \"new_user123\",\n    \"nickname\": \"\ubaa8\ube4c\ub7ec\"\n  }\n}\n</code></pre>"},{"location":"auth/signup/#response-400","title":"\ud83d\udd39 Response 400","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"username\": \"\uc774\ubbf8 \uc0ac\uc6a9 \uc911\uc778 \uc544\uc774\ub514\uc785\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/signup/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li><code>username</code>, <code>email</code>\uc740 \uc911\ubcf5 \uc5ec\ubd80\ub97c \uac80\uc0ac\ud569\ub2c8\ub2e4.</li> <li><code>password</code>\ub294 8\uc790 \uc774\uc0c1\uc774\uc5b4\uc57c \ud558\uba70, \ud544\uc218 \uc785\ub825\uc785\ub2c8\ub2e4.</li> <li><code>nickname</code>\uc740 \uc0ac\uc6a9\uc790 \ud45c\uc2dc \uc774\ub984\uc73c\ub85c, \ubcc4\uba85\ucc98\ub7fc \uc0ac\uc6a9\ub429\ub2c8\ub2e4.</li> <li>\uc774\uba54\uc77c \uc778\uc99d\uc774 \uc644\ub8cc\ub418\uc5b4\uc57c\ub9cc \ud68c\uc6d0\uac00\uc785\uc774 \uc131\uacf5\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/token_refresh/","title":"\u2705 \ud1a0\ud070 \uac31\uc2e0 API","text":""},{"location":"auth/token_refresh/#post-authtokenrefresh","title":"\ud83d\udd3d POST <code>/auth/token/refresh/</code>","text":"<p>Refresh \ud1a0\ud070\uc744 \ud1b5\ud574 Access \ud1a0\ud070\uc744 \uc7ac\ubc1c\uae09\ubc1b\uc2b5\ub2c8\ub2e4.</p>"},{"location":"auth/token_refresh/#request","title":"\ud83d\udd38 Request","text":"<pre><code>{\n  \"refresh\": \"eyJ0eXAiOiJKV1QiLCJhbGci...\"\n}\n</code></pre>"},{"location":"auth/token_refresh/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"access\": \"eyJ0eXAiOiJKV1QiLCJhbGci...\"\n  }\n}\n</code></pre>"},{"location":"auth/token_refresh/#response-401","title":"\ud83d\udd39 Response 401","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"refresh\": \"Refresh \ud1a0\ud070\uc774 \uc720\ud6a8\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/token_refresh/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\ud074\ub77c\uc774\uc5b8\ud2b8\ub294 \uc8fc\uae30\uc801\uc73c\ub85c access \ud1a0\ud070\uc744 \uac31\uc2e0\ud558\uae30 \uc704\ud574 \uc774 API\ub97c \ud638\ucd9c\ud569\ub2c8\ub2e4.</li> <li>\uc720\ud6a8\ud55c refresh \ud1a0\ud070\uc774 \ud544\uc694\ud558\uba70, refresh \ud1a0\ud070\uc774 \ub9cc\ub8cc\ub418\uba74 \uc7ac\ub85c\uadf8\uc778\uc774 \ud544\uc694\ud569\ub2c8\ub2e4.</li> <li>\uc751\ub2f5\uc5d0\ub294 \uc0c8\ub85c\uc6b4 access \ud1a0\ud070\ub9cc \ud3ec\ud568\ub429\ub2c8\ub2e4.</li> </ul>"},{"location":"auth/user_mypage/","title":"\u2705 \ub9c8\uc774\ud398\uc774\uc9c0 \uc815\ubcf4 API","text":""},{"location":"auth/user_mypage/#get-authusermypage","title":"\ud83d\udd3d GET <code>/auth/user/mypage/</code>","text":"<p>\ub85c\uadf8\uc778\ub41c \uc0ac\uc6a9\uc790\uc758 \ub9c8\uc774\ud398\uc774\uc9c0 \uc815\ubcf4\ub97c \uc870\ud68c\ud569\ub2c8\ub2e4.</p>"},{"location":"auth/user_mypage/#request","title":"\ud83d\udd38 Request","text":"<p>\ud5e4\ub354\uc5d0 JWT access token\uc744 \ud3ec\ud568\ud574\uc57c \ud569\ub2c8\ub2e4.</p> <pre><code>Authorization: Bearer &lt;access_token&gt;\n</code></pre>"},{"location":"auth/user_mypage/#response-200","title":"\ud83d\udd39 Response 200","text":"<pre><code>{\n  \"success\": true,\n  \"data\": {\n    \"nickname\": \"\ubaa8\ube4c\ub7ec\",\n    \"ride_score\": 1240,\n    \"app_usage_count\": 32,\n    \"total_saved_money\": 7850\n  }\n}\n</code></pre>"},{"location":"auth/user_mypage/#response-401","title":"\ud83d\udd39 Response 401","text":"<pre><code>{\n  \"success\": false,\n  \"data\": {\n    \"detail\": \"\uc720\ud6a8\ud558\uc9c0 \uc54a\uc740 \ud1a0\ud070\uc785\ub2c8\ub2e4.\"\n  }\n}\n</code></pre>"},{"location":"auth/user_mypage/#_1","title":"\ud83d\udd16 \uc124\uba85","text":"<ul> <li>\ub9c8\uc774\ud398\uc774\uc9c0 \uc815\ubcf4\uc5d0\ub294 \ub2c9\ub124\uc784, \ub204\uc801 \uc810\uc218, \uc571 \uc0ac\uc6a9 \ud69f\uc218, \uc808\uc57d \uae08\uc561 \ub4f1\uc774 \ud3ec\ud568\ub429\ub2c8\ub2e4.</li> <li>\ud574\ub2f9 \ub370\uc774\ud130\ub294 \uc0ac\uc6a9\uc790 \ud65c\ub3d9 \uae30\ubc18\uc73c\ub85c \uc790\ub3d9 \ub204\uc801\ub429\ub2c8\ub2e4.</li> <li>\ub85c\uadf8\uc778\ud55c \uc0ac\uc6a9\uc790 \ubcf8\uc778\uc758 \uc815\ubcf4\ub9cc \uc870\ud68c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>"}]}